---
// cmd palette + settings panel — shared across every page
---
<button id="settings-toggle" class="settings-btn" type="button" title="settings (,)">
  <kbd>,</kbd> settings
</button>
<div class="cmd-hint">press <kbd>/</kbd> for cmd</div>
<div class="cmd" id="cmd">
  <div class="log" id="cmd-log"></div>
  <span class="carat">$</span>
  <input id="cmd-input" type="text" autocomplete="off" spellcheck="false" placeholder="help, theme amber, scan off, density compact, banner 1, home ..." />
</div>

<div class="settings-panel" id="settings">
  <div class="settings-head">settings <span class="x" id="settings-close">×</span></div>
  <div class="settings-body">
    <div class="setting-row">
      <div class="setting-label">theme</div>
      <div class="setting-opts" data-key="theme">
        <button class="setting-opt" data-val="phosphor">phosphor</button>
        <button class="setting-opt" data-val="amber">amber</button>
        <button class="setting-opt" data-val="ice">ice</button>
        <button class="setting-opt" data-val="paper">paper</button>
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">scanlines</div>
      <div class="setting-opts" data-key="scan">
        <button class="setting-opt" data-val="off">off</button>
        <button class="setting-opt" data-val="subtle">subtle</button>
        <button class="setting-opt" data-val="heavy">heavy</button>
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">background image</div>
      <div class="setting-opts" data-key="bg">
        <button class="setting-opt" data-val="on">on</button>
        <button class="setting-opt" data-val="off">off</button>
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">density</div>
      <div class="setting-opts" data-key="density">
        <button class="setting-opt" data-val="comfy">comfy</button>
        <button class="setting-opt" data-val="compact">compact</button>
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-label">banner</div>
      <div class="setting-opts" data-key="banner-idx">
        <button class="setting-opt" data-val="0">[1]</button>
        <button class="setting-opt" data-val="1">[2]</button>
        <button class="setting-opt" data-val="2">[3]</button>
        <button class="setting-opt" data-val="3">[4]</button>
        <button class="setting-opt" data-val="random">rand</button>
      </div>
    </div>
  </div>
</div>
