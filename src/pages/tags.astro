---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((p) => ({
    slug: p.id,
    title: p.data.title,
    date: p.data.date.toISOString().slice(0, 10),
    tags: p.data.tags,
  }));

const byTag: Record<string, typeof posts> = {};
for (const p of posts) for (const t of p.tags) (byTag[t] = byTag[t] || []).push(p);
const allTags = Object.keys(byTag).sort();
---
<BaseLayout title="tags · justin.vc" description="writing by tag" canonical="https://justin.vc/tags/">
  <div class="wrap tags-wrap">
    <nav class="crumb">
      <a href="/">~/</a>
      <span class="sep">/</span>
      <span class="here">tags</span>
      <span class="spacer"></span>
      <span class="meta" id="crumb-count">—</span>
    </nav>

    <h1 class="tags-title">tags</h1>
    <p class="tags-subtitle">// writing grouped by tag. click a pill to filter.</p>

    <div class="filter-bar" id="filter-bar">
      <span class="filter-label">filter</span>
      <span id="filter-tags"></span>
      <button class="filter-clear" id="filter-clear">clear ×</button>
    </div>

    <div id="groups"></div>
  </div>

  <script is:inline define:vars={{ posts, byTag, allTags }}>
    window.__TAGS__ = { posts, byTag, allTags };
  </script>
  <script is:inline>
    (() => {
      const { posts, byTag, allTags } = window.__TAGS__;
      let active = new Set();

      const readHash = () => {
        active = new Set(decodeURIComponent((location.hash || '').slice(1)).split(',').filter(Boolean));
      };
      readHash();

      function renderFilter() {
        const el = document.getElementById('filter-tags');
        el.innerHTML = allTags.map(t => {
          const count = (byTag[t] || []).length;
          const on = active.has(t) ? ' on' : '';
          return `<a class="tag-pill${on}" data-tag="${t}" href="#">${t}<span style="color:var(--fg-dim);margin-left:0.3rem">${count}</span></a>`;
        }).join('');
        document.getElementById('filter-clear').style.display = active.size ? '' : 'none';
      }

      function matches(post) {
        if (!active.size) return true;
        return (post.tags || []).some(t => active.has(t));
      }

      function renderGroups() {
        const el = document.getElementById('groups');
        const tagsToShow = active.size ? [...active].filter(t => byTag[t]) : allTags;
        if (!tagsToShow.length) {
          el.innerHTML = '<p class="empty-msg">// no posts match that filter.</p>';
          document.getElementById('crumb-count').textContent = '0 posts';
          return;
        }
        let postCount = 0;
        el.innerHTML = tagsToShow.map(t => {
          const ps = (byTag[t] || []).filter(matches);
          postCount += ps.length;
          if (!ps.length) return '';
          return `
            <section class="tag-group">
              <h2 class="tag-group-head" id="${t}">
                <span>${t}</span>
                <span class="count">${ps.length}</span>
                <span class="rule"></span>
              </h2>
              <ul class="post-list">
                ${ps.map(p => `
                  <li><a class="post" href="/writing/${p.slug}/">
                    <span class="post-date">${p.date}</span>
                    <span class="post-title">${p.title}</span>
                    <span class="post-meta">${(p.tags || []).join(' · ')}</span>
                  </a></li>
                `).join('')}
              </ul>
            </section>`;
        }).join('');
        const total = active.size ? postCount : posts.length;
        document.getElementById('crumb-count').textContent = `${total} post${total === 1 ? '' : 's'}${active.size ? ' · filtered' : ''}`;
      }

      function rerender() { renderFilter(); renderGroups(); }
      rerender();

      document.getElementById('filter-bar').addEventListener('click', e => {
        const pill = e.target.closest('.tag-pill');
        if (!pill) return;
        e.preventDefault();
        const t = pill.dataset.tag;
        if (active.has(t)) active.delete(t); else active.add(t);
        location.hash = [...active].join(',');
        rerender();
      });
      document.getElementById('filter-clear').addEventListener('click', () => {
        active.clear(); location.hash = ''; rerender();
      });
      window.addEventListener('hashchange', () => { readHash(); rerender(); });

      // cmd extras
      document.addEventListener('DOMContentLoaded', () => {
        if (!window.jvc) return;
        window.jvc.on('tag', (arg) => {
          if (!arg) return 'tag: usage — tag <name>';
          if (!byTag[arg]) return `tag: no '${arg}'. available: ${allTags.join(', ')}`;
          active = new Set([arg]); location.hash = arg; rerender();
          const el = document.getElementById(arg);
          if (el) el.scrollIntoView({ behavior: 'smooth' });
          window.jvc.closeCmd();
        });
        window.jvc.on('clear-filter', () => { active.clear(); location.hash = ''; rerender(); });
        window.jvc.on('writing', () => { window.location.href = '/#post-list'; });
      });
    })();
  </script>
</BaseLayout>

<style is:global>
  :root { --bg-image: url('/bg.avif'); }
  .tags-wrap {
    position: relative; z-index: 2;
    max-width: 720px; margin: 0 auto;
    padding: 2.5rem 1.75rem 8rem;
  }

  .crumb {
    font-size: 0.78rem; color: var(--fg-mute);
    border-bottom: 1px solid var(--rule-dim);
    padding-bottom: 0.75rem; margin-bottom: 2rem;
    display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
  }
  .crumb a { color: var(--link); text-decoration: none; }
  .crumb a:hover { color: var(--hot); }
  .crumb .sep { color: var(--fg-dim); }
  .crumb .here { color: var(--fg); }
  .crumb .spacer { flex: 1; }
  .crumb .meta { color: var(--fg-dim); font-variant-numeric: tabular-nums; }

  h1.tags-title {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700; font-size: 1.25rem;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.4rem;
  }
  h1.tags-title::before { content: '$ ls '; color: var(--fg-dim); font-weight: 400; letter-spacing: 0; }
  .tags-subtitle { color: var(--fg-mute); font-size: 0.88rem; margin-bottom: 2rem; }

  .filter-bar {
    display: flex; flex-wrap: wrap; gap: 0.4rem;
    padding: 0.75rem 0.9rem; margin-bottom: 1.75rem;
    border: 1px solid var(--rule-dim); background: var(--bg-elev);
  }
  .filter-label {
    font-size: 0.72rem; color: var(--fg-dim);
    letter-spacing: 0.12em; text-transform: uppercase;
    margin-right: 0.3rem; align-self: center;
  }
  .filter-clear {
    margin-left: auto; font-size: 0.72rem; color: var(--fg-mute);
    background: transparent; border: 1px solid var(--rule-dim);
    padding: 2px 7px; border-radius: 2px; cursor: pointer; font-family: inherit;
  }
  .filter-clear:hover { color: var(--hot); border-color: var(--hot); }

  .tag-group { margin-bottom: 2rem; }
  .tag-group-head {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 0.7rem;
    scroll-margin-top: 1rem;
  }
  .tag-group-head::before { content: '##'; color: var(--fg-dim); font-weight: 400; }
  .tag-group-head .count { color: var(--fg-dim); font-weight: 400; letter-spacing: 0; font-size: 0.75rem; }
  .tag-group-head .rule { flex: 1; height: 1px; background: linear-gradient(90deg, var(--rule), transparent); }

  .post-list { list-style: none; }
  .post {
    display: grid; grid-template-columns: 90px 1fr auto;
    gap: 1rem; align-items: baseline;
    padding: 0.5rem 0; border-bottom: 1px dashed var(--rule-dim);
    color: var(--fg); text-decoration: none;
    transition: color 0.15s, padding-left 0.15s;
  }
  .post:last-child { border-bottom: none; }
  .post:hover { color: var(--hot); padding-left: 0.5rem; }
  .post:hover .post-date, .post:hover .post-meta { color: var(--hot); }
  .post-date { font-variant-numeric: tabular-nums; color: var(--fg-dim); font-size: 0.82rem; }
  .post-title { font-size: 0.92rem; }
  .post-meta { color: var(--fg-dim); font-size: 0.78rem; }

  .empty-msg { color: var(--fg-dim); font-size: 0.85rem; padding: 1rem 0; }

  @media (max-width: 640px) {
    .tags-wrap { padding: 1.25rem 1rem 6rem; }
    .post { grid-template-columns: 80px 1fr; }
    .post-meta { display: none; }
  }
</style>
